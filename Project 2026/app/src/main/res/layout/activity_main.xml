<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D2B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 SPACE COLONY"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Colony Management System"
            android:textColor="#8888AA"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <!-- Crew summary card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A3E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COLONY STATUS"
                android:textColor="#8888AA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Row of status counts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvQuartersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#4FC3F7"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏠 Quarters"
                        android:textColor="#8888AA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvSimulatorCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFD54F"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎮 Simulator"
                        android:textColor="#8888AA"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvMissionCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#EF5350"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯 Mission"
                        android:textColor="#8888AA"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Navigation buttons -->
        <Button
            android:id="@+id/btnRecruit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="➕  Recruit New Crew Member"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnQuarters"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🏠  Quarters"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A237E"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnSimulator"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🎮  Simulator"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F57F17"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnMissionControl"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🎯  Mission Control"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B71C1C"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnStats"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📊  Statistics"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B5E20"
            android:layout_marginBottom="12dp"/>

        <!-- Missions completed counter -->
        <TextView
            android:id="@+id/tvTotalMissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total missions completed: 0"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>